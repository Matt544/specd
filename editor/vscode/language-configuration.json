{
  "comments": {
    "blockComment": ["{#", "#}"]
  },
  "brackets": [
    ["{#", "#}"],
    ["{%", "%}"],
    ["{{", "}}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{#", "close": " #}", "notIn": ["string"] },
    { "open": "{%", "close": " %}", "notIn": ["string"] },
    { "open": "{{", "close": " }}", "notIn": ["string"] },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"", "notIn": ["string"] },
    { "open": "'", "close": "'", "notIn": ["string"] },
    { "open": "`", "close": "`", "notIn": ["string", "comment"] }
  ],
  "surroundingPairs": [
    ["{%", "%}"],
    ["{{", "}}"],
    ["{#", "#}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""],
    ["'", "'"],
    ["`", "`"]
  ],
  "folding": {
    "markers": {
      "start": "{%[-\\s]*(block|filter|for|if|macro|raw|call)",
      "end": "{%[-\\s]*end(block|filter|for|if|macro|raw|call)"
    }
  }
}
