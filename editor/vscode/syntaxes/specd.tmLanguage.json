{
  "name": "Specd Markdown",
  "scopeName": "text.html.markdown.jinja.specd",
  "patterns": [
    { "include": "#jinja-raw-block" },
    { "include": "#jinja-inline-code" },
    { "include": "#jinja-comment" },
    { "include": "#jinja-expression" },
    { "include": "#jinja-statement" },
    { "include": "text.html.markdown" }
  ],
  "repository": {
    "jinja-inline-code": {
      "begin": "(`+)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.raw.markdown" }
      },
      "end": "(\\1)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.raw.markdown" }
      },
      "patterns": [
        { "include": "#jinja-expression" },
        { "include": "#jinja-statement" },
        { "include": "#jinja-comment" },
        {
          "match": ".",
          "name": "markup.inline.raw.string.markdown"
        }
      ]
    },
    "jinja-raw-block": {
      "begin": "({%)\\s*(raw)\\s*(%})",
      "beginCaptures": {
        "1": { "name": "punctuation.section.tag.begin.jinja" },
        "2": { "name": "keyword.control.flow.jinja" },
        "3": { "name": "punctuation.section.tag.end.jinja" }
      },
      "end": "({%)\\s*(endraw)\\s*(%})",
      "endCaptures": {
        "1": { "name": "punctuation.section.tag.begin.jinja" },
        "2": { "name": "keyword.control.flow.jinja" },
        "3": { "name": "punctuation.section.tag.end.jinja" }
      },
      "name": "comment.block.raw.jinja"
    },
    "jinja-comment": {
      "begin": "{#-?",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.comment.begin.jinja" }
      },
      "end": "-?#}",
      "endCaptures": {
        "0": { "name": "punctuation.definition.comment.end.jinja" }
      },
      "name": "comment.block.jinja"
    },
    "jinja-expression": {
      "begin": "{{-?",
      "beginCaptures": {
        "0": { "name": "punctuation.section.interpolation.begin.jinja" }
      },
      "end": "-?}}",
      "endCaptures": {
        "0": { "name": "punctuation.section.interpolation.end.jinja" }
      },
      "name": "meta.interpolation.jinja",
      "patterns": [
        { "include": "#jinja-innards" }
      ]
    },
    "jinja-statement": {
      "begin": "{%-?",
      "beginCaptures": {
        "0": { "name": "punctuation.section.tag.begin.jinja" }
      },
      "end": "-?%}",
      "endCaptures": {
        "0": { "name": "punctuation.section.tag.end.jinja" }
      },
      "name": "meta.tag.template.jinja",
      "patterns": [
        { "include": "#jinja-innards" }
      ]
    },
    "jinja-innards": {
      "patterns": [
        {
          "match": "\\b(block|endblock|extends|from|import|include|macro|endmacro|call|endcall|filter|endfilter|set|for|endfor|if|elif|else|endif|raw|endraw|with|endwith|autoescape|endautoescape|do|trans|endtrans|pluralize|debug|in|recursive|as)\\b",
          "name": "keyword.control.flow.jinja"
        },
        {
          "match": "\\b(and|or|not|is)\\b",
          "name": "keyword.operator.logical.jinja"
        },
        {
          "match": "\\b(true|True|false|False|none|None)\\b",
          "name": "constant.language.jinja"
        },
        {
          "match": "\\b(loop|super|self|varargs|kwargs|caller)\\b",
          "name": "variable.language.jinja"
        },
        {
          "match": "\\b\\d+(\\.\\d+)?\\b",
          "name": "constant.numeric.jinja"
        },
        {
          "match": "(\\|)\\s*([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "punctuation.separator.pipe.jinja" },
            "2": { "name": "support.function.filter.jinja" }
          }
        },
        {
          "match": "(\\.)([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "punctuation.accessor.jinja" },
            "2": { "name": "variable.other.property.jinja" }
          }
        },
        {
          "match": "(==|!=|<=?|>=?)",
          "name": "keyword.operator.comparison.jinja"
        },
        {
          "match": "(\\+|-|\\*\\*|\\*|//|/|%)",
          "name": "keyword.operator.arithmetic.jinja"
        },
        {
          "match": "=",
          "name": "keyword.operator.assignment.jinja"
        },
        {
          "match": "[,:]",
          "name": "punctuation.separator.jinja"
        },
        {
          "begin": "\"",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.jinja" }
          },
          "end": "\"",
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.jinja" }
          },
          "name": "string.quoted.double.jinja",
          "patterns": [
            { "include": "#jinja-string-escapes" }
          ]
        },
        {
          "begin": "'",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.jinja" }
          },
          "end": "'",
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.jinja" }
          },
          "name": "string.quoted.single.jinja",
          "patterns": [
            { "include": "#jinja-string-escapes" }
          ]
        },
        {
          "begin": "\\[",
          "beginCaptures": {
            "0": { "name": "punctuation.section.brackets.begin.jinja" }
          },
          "end": "\\]",
          "endCaptures": {
            "0": { "name": "punctuation.section.brackets.end.jinja" }
          },
          "patterns": [
            { "include": "#jinja-innards" }
          ]
        },
        {
          "begin": "\\(",
          "beginCaptures": {
            "0": { "name": "punctuation.section.parens.begin.jinja" }
          },
          "end": "\\)",
          "endCaptures": {
            "0": { "name": "punctuation.section.parens.end.jinja" }
          },
          "patterns": [
            { "include": "#jinja-innards" }
          ]
        },
        {
          "match": "[a-zA-Z_][a-zA-Z0-9_]*",
          "name": "variable.other.jinja"
        }
      ]
    },
    "jinja-string-escapes": {
      "patterns": [
        {
          "match": "\\\\[\\\\\"'abfnrtv]",
          "name": "constant.character.escape.jinja"
        },
        {
          "match": "\\\\x[0-9A-Fa-f]{2}",
          "name": "constant.character.escape.hex.jinja"
        },
        {
          "match": "\\\\u[0-9A-Fa-f]{4}",
          "name": "constant.character.escape.unicode.jinja"
        }
      ]
    }
  }
}
