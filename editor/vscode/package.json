{
  "name": "specd-md",
  "displayName": "Specd Markdown",
  "description": "Syntax highlighting for *.specd.md files (Markdown + Jinja2 templates)",
  "version": "0.1.0",
  "publisher": "specd",
  "license": "MIT",
  "engines": {
    "vscode": "^1.75.0"
  },
  "main": "./out/extension.js",
"scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "typescript": "^5.0.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "specd-md",
        "aliases": [
          "Specd Markdown",
          "specd"
        ],
        "extensions": [
          ".specd.md"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "configuration": {
      "title": "Specd Markdown",
      "properties": {
        "specd-md.jinjaDelimiterColor": {
          "type": "string",
          "description": "Override color for Jinja delimiters ({{ }}, {% %}, {# #}) inside inline code spans. Defaults to #D7BA7D on dark themes, #098658 on light themes."
        },
        "specd-md.jinjaContentColor": {
          "type": "string",
          "description": "Override color for Jinja expression content inside inline code spans. Defaults to #C586C0 on dark themes, #AF00DB on light themes."
        },
        "specd-md.placeholderColor": {
          "type": "string",
          "description": "Override color for angle-bracket placeholders (<name>, <<name>>). Defaults to #D7BA7D on dark themes, #AF00DB on light themes."
        }
      }
    },
    "configurationDefaults": {
      "[specd-md]": {
        "editor.wordWrap": "on",
        "editor.wrappingIndent": "indent",
        "editor.tabSize": 2
      }
    },
    "grammars": [
      {
        "language": "specd-md",
        "scopeName": "text.html.markdown.jinja.specd",
        "path": "./syntaxes/specd.tmLanguage.json",
        "embeddedLanguages": {
          "meta.embedded.block.html": "html",
          "source.js": "javascript",
          "source.css": "css",
          "source.json": "json",
          "source.ts": "typescript",
          "source.python": "python",
          "source.shell": "shellscript",
          "source.yaml": "yaml"
        }
      }
    ]
  }
}
